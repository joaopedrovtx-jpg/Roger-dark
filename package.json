{
  "name": "gateway-darkpay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d mysql || echo \"Docker opcional. Local usa SQLite (file:./dev.db)\"",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "db:seed": "node scripts/seed-real.mjs",
    "db:reset": "docker compose down -v && docker compose up -d mysql && echo 'Aguarde ~20s e rode: npm run db:seed'",
    "dev:real": "next dev",
    "setup:real": "docker compose up -d mysql && echo 'Aguardando MySQL...' && sleep 25 && npx prisma generate && node scripts/seed-real.mjs",
    "setup": "prisma generate && prisma db push && node scripts/seed-real.mjs",
    "smoke:security": "node scripts/smoke-security.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.1.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
