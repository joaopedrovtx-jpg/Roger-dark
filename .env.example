# ═══════════════════════════════════════════════════════════
# DarkPay — variáveis de ambiente
# Copie para .env e preencha. NUNCA commite .env real.
# ═══════════════════════════════════════════════════════════

NEXT_PUBLIC_DARKPAY_DATA_MODE=http
# NEXT_PUBLIC_APP_URL=https://seu-dominio.com
# NEXT_PUBLIC_DARKPAY_API_BASE=/api/v1

# ── Banco ────────────────────────────────────────────────
# Local SQLite (dev):
DATABASE_URL="file:./dev.db"
# Produção MySQL:
# DATABASE_URL=mysql://user:senha@host:3306/darkpay

# ── Sessão / cookies (OBRIGATÓRIO em produção) ───────────
# Gere: openssl rand -hex 32
SESSION_SECRET=change-me-use-openssl-rand-hex-32-chars-min
# FORCE_INSECURE_COOKIE=1   # só localhost http
# COOKIE_SECURE=1           # força Secure em HTTPS

# ── Segurança ────────────────────────────────────────────
# REQUIRE_ADMIN_2FA=1       # força 2FA admin (default em production)
# REQUIRE_ADMIN_2FA=0       # desliga policy
# CSRF_STRICT=1             # force CSRF em dev
# CSRF_ALLOW_MISSING_ORIGIN=1
# REQUIRE_WEBHOOK_HMAC=1    # fail-closed webhooks sem secret
# NUNCA em produção:
# ALLOW_MOCK_DATA=1

# ── PodPay ───────────────────────────────────────────────
PODPAY_API_KEY=
PODPAY_ENV=sandbox
# PODPAY_POSTBACK_BASE_URL=https://seu-dominio.com
PODPAY_WEBHOOK_SECRET=

# ── Velana ───────────────────────────────────────────────
# Preferível salvar pk_/sk_ no Admin → Credenciais
# VELANA_SECRET_KEY=
# VELANA_PUBLIC_KEY=
# VELANA_POSTBACK_BASE_URL=https://seu-dominio.com
# VELANA_WEBHOOK_SECRET=
# VELANA_REQUIRE_HMAC=1
# VELANA_ALLOW_UNSIGNED_WEBHOOK=1  # só se Velana não enviar HMAC (não recomendado)

# ── E-mail (redefinição de senha / welcome) ──────────────
# Com RESEND_API_KEY envia de verdade; sem chave, loga no console (dev).
# RESEND_API_KEY=re_...
# EMAIL_FROM=DarkPay <noreply@seu-dominio.com>
# NEXT_PUBLIC_APP_URL=https://seu-dominio.com
# APP_URL=https://seu-dominio.com

# ── Seed ─────────────────────────────────────────────────
SEED_PASSWORD=DarkPay@123
